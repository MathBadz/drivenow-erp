# =============================================================================
# DriveNow ERP — Docker Compose secrets
# Copy to .env and fill in, or generate everything at once:
#   pwsh ./scripts/generate-secrets.ps1        (Windows)
#   ./scripts/generate-secrets.sh              (Linux/macOS/VPS)
# .env is read automatically by `docker compose`.
# =============================================================================

# Shared across ALL services — MUST be identical everywhere.
JWT_SECRET=
SERVICE_TOKEN=

# Per-service Laravel application keys (format: base64:....).
APPKEY_AUTH=
APPKEY_FLEET=
APPKEY_RENTAL=
APPKEY_CRM=
APPKEY_BILLING=
APPKEY_MAINTENANCE=
APPKEY_ANALYTICS=
APPKEY_CLIENT=

# Runtime toggles.
APP_DEBUG=false
# Set to true for the FIRST `docker compose up` only, to migrate+seed demo data.
APP_AUTO_SEED=false
